        "axis": { "$value": "#b7b0a9" },
        "label": { "$value": "#d0c9c3" },
        "tooltip-bg": { "$value": "#2c2a27" }
      }
    },
    "diagram": {
      "canvas": { "$value": "#231e1a" },
      "node-fill": { "$value": "#2c2a27" },
      "node-stroke": { "$value": "#e89f53" },
      "link": { "$value": "#8c8681" },
      "spine-accent": { "$value": "#e89f53" },
      "label": { "$value": "#f1ece7" },
