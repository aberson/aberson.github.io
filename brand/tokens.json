{
  "$description": "on-brand monet-san-giorgio preset — HAND-AUTHORED vision-judge mood anchor (brand-fidelity benchmark Step 4, issue #33). NOT extracted from a live site; not a general-purpose UI preset. Palette grounded in Monet's \"San Giorgio Maggiore at Dusk\" (1908): warm gold/amber/orange sky, blue-violet water, hazy dusk -- warm, saturated, low-key-warm. Excluded from the fidelity rollup; used only as a mood-anchor image pairing for the vision judge. All declared text/bg pairs pass WCAG 2 AA.",
  "$extensions": {
    "onbrand": {
      "schemaVersion": 1
    }
  },
  "color": {
    "$type": "color",
    "primitive": {
      "brand": {
        "$description": "Brand ramp, 12 steps light-to-dark (Radix-style scale).",
        "1": { "$value": "#fefdfb" },
        "2": { "$value": "#fdf9f5" },
        "3": { "$value": "#faf2e9" },
        "4": { "$value": "#f6e8d8" },
        "5": { "$value": "#f1dbc2" },
        "6": { "$value": "#eacaa5" },
        "7": { "$value": "#e1b37e" },
        "8": { "$value": "#d5964e" },
        "9": { "$value": "#b8762b" },
        "10": { "$value": "#a66b27" },
        "11": { "$value": "#905d22" },
        "12": { "$value": "#533614" }
      },
      "neutral": {
        "$description": "Cool-gray neutral ramp, 12 steps light-to-dark.",
        "1": { "$value": "#fdfcfc" },
        "2": { "$value": "#faf9f8" },
        "3": { "$value": "#f4f2f0" },
        "4": { "$value": "#edeae8" },
        "5": { "$value": "#e5e1dd" },
        "6": { "$value": "#dad5cf" },
        "7": { "$value": "#cac2bb" },
        "8": { "$value": "#b2a59a" },
        "9": { "$value": "#99897b" },
        "10": { "$value": "#897869" },
        "11": { "$value": "#706256" },
        "12": { "$value": "#2a2521" }
      }
    },
    "semantic": {
      "bg": { "$value": "#fdfcfc" },
      "surface": { "$value": "#ffffff" },
      "text": { "$value": "#2a2521" },
      "text-muted": { "$value": "#706256" },
      "border": { "$value": "#e5e1dd" },
      "accent": { "$value": "#b8762b" },
      "code-bg": { "$value": "#f4f2f0" },
      "shadow-color": { "$value": "#2a252129" }
    },
    "status": {
      "success": {
        "fg": { "$value": "#1e6736" },
        "bg": { "$value": "#e2f1da" }
      },
      "warning": {
        "fg": { "$value": "#8a4d0f" },
        "bg": { "$value": "#fbe6c1" }
      },
      "danger": {
        "fg": { "$value": "#9d3125" },
        "bg": { "$value": "#f7ddd9" }
      },
      "info": {
        "fg": { "$value": "#473285" },
        "bg": { "$value": "#e4dff6" }
      }
    },
    "chart": {
      "categorical": {
        "$description": "8 distinguishable series colors for light backgrounds.",
        "1": { "$value": "#da8a2f" },
        "2": { "$value": "#d05825" },
        "3": { "$value": "#6550a5" },
        "4": { "$value": "#3a7b88" },
        "5": { "$value": "#b87a8f" },
        "6": { "$value": "#cfa117" },
        "7": { "$value": "#724731" },
        "8": { "$value": "#a68fbc" }
      },
      "sequential": {
        "$description": "7-step light-to-dark sequential ramp derived from the brand hue.",
        "1": { "$value": "#faf2e9" },
        "2": { "$value": "#f1dbc2" },
        "3": { "$value": "#e6c196" },
        "4": { "$value": "#dba465" },
        "5": { "$value": "#cf8531" },
        "6": { "$value": "#a66b27" },
        "7": { "$value": "#533614" }
      },
      "chrome": {
        "grid": { "$value": "#edeae8" },
        "axis": { "$value": "#b2a59a" },
        "label": { "$value": "#706256" },
        "tooltip-bg": { "$value": "#ffffff" }
      }
    },
    "diagram": {
      "canvas": { "$value": "#fdf9f5" },
      "node-fill": { "$value": "#ffffff" },
      "node-stroke": { "$value": "#e1b37e" },
      "link": { "$value": "#99897b" },
      "spine-accent": { "$value": "#b8762b" },
      "label": { "$value": "#2a2521" },
      "chip-highlight": { "$value": "#faf2e9" },
      "warning": { "$value": "#c8842a" }
    }
  },
  "font": {
    "$type": "fontFamily",
    "sans": { "$value": ["Inter", "Segoe UI", "system-ui", "sans-serif"] },
    "heading": { "$value": ["Manrope", "Inter", "Segoe UI", "system-ui", "sans-serif"] },
    "mono": { "$value": ["JetBrains Mono", "Cascadia Code", "Consolas", "monospace"] }
  },
  "type": {
    "size": {
      "$type": "dimension",
      "base": { "$value": "1rem" }
    },
    "scale": {
      "$type": "dimension",
      "$description": "Fluid type scale, Utopia method (1rem@360px -> 1.125rem@1240px base, 1.2/1.25 ratio).",
      "step--1": { "$value": "clamp(0.8333rem, 0.8101rem + 0.1031vw, 0.9rem)" },
      "step-0": { "$value": "clamp(1rem, 0.9489rem + 0.2273vw, 1.125rem)" },
      "step-1": { "$value": "clamp(1.2rem, 1.131rem + 0.3068vw, 1.4063rem)" },
      "step-2": { "$value": "clamp(1.44rem, 1.3468rem + 0.4141vw, 1.7578rem)" },
      "step-3": { "$value": "clamp(1.728rem, 1.6022rem + 0.5591vw, 2.1973rem)" },
      "step-4": { "$value": "clamp(2.0736rem, 1.9037rem + 0.7547vw, 2.7466rem)" },
      "step-5": { "$value": "clamp(2.4883rem, 2.2593rem + 1.0182vw, 3.4332rem)" }
    },
    "weight": {
      "$type": "fontWeight",
      "regular": { "$value": 400 },
      "medium": { "$value": 500 },
      "semibold": { "$value": 600 },
      "bold": { "$value": 700 }
    },
    "line-height": {
      "$type": "number",
      "tight": { "$value": 1.2 },
      "base": { "$value": 1.55 },
      "loose": { "$value": 1.7 }
    }
  },
  "space": {
    "$type": "dimension",
    "$description": "4px grid: 4, 8, 12, 16, 24, 32, 40, 48, 64, 96 px.",
    "1": { "$value": "0.25rem" },
    "2": { "$value": "0.5rem" },
    "3": { "$value": "0.75rem" },
    "4": { "$value": "1rem" },
    "5": { "$value": "1.5rem" },
    "6": { "$value": "2rem" },
    "7": { "$value": "2.5rem" },
    "8": { "$value": "3rem" },
    "9": { "$value": "4rem" },
    "10": { "$value": "6rem" }
  },
  "radius": {
    "$type": "dimension",
    "sm": { "$value": "4px" },
    "md": { "$value": "8px" },
    "lg": { "$value": "12px" },
    "pill": { "$value": "999px" }
  },
  "shadow": {
    "$type": "shadow",
    "elevation-1": {
      "$value": {
        "color": "#1f242c14",
        "offsetX": "0px",
        "offsetY": "1px",
        "blur": "2px",
        "spread": "0px"
      }
    },
    "elevation-2": {
      "$value": {
        "color": "#1f242c1f",
        "offsetX": "0px",
        "offsetY": "2px",
        "blur": "8px",
        "spread": "-1px"
      }
    },
    "elevation-3": {
      "$value": {
        "color": "#1f242c29",
        "offsetX": "0px",
        "offsetY": "8px",
        "blur": "24px",
        "spread": "-4px"
      }
    }
  },
  "motion": {
    "duration": {
      "$type": "duration",
      "fast": { "$value": "120ms" },
      "base": { "$value": "200ms" },
      "slow": { "$value": "400ms" }
    },
    "easing": {
      "$type": "cubicBezier",
      "$description": "Reduced-motion preferences are always respected by consumers.",
      "standard": { "$value": [0.4, 0, 0.2, 1] },
      "decelerate": { "$value": [0, 0, 0.2, 1] },
      "accelerate": { "$value": [0.4, 0, 1, 1] }
    }
  }
}
