---
// BaseLayout — the site's HTML shell.
// Imports the global stylesheet (which pulls in the vendored brand tokens), sets
// up head meta, and renders page content through <slot />. Light/dark is handled
// entirely by the brand tokens' `prefers-color-scheme` flip plus `color-scheme`
// in global.css, so the shell honors the visitor's OS preference with no JS.
//
// The persistent site chrome (sticky Header above the page slot, Footer below)
// lives here so every page inherits it. Page-specific content flows through the
// <slot />, which each page wraps in its own <main> landmark.
import "../styles/global.css";
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE_NAME, VALUE_PROP } from "../consts";

interface Props {
  title?: string;
  description?: string;
}

// Defaults derive from the consts SSOT so the name + description can't drift.
const {
  title = `${SITE_NAME} — Applied AI Engineer`,
  description = VALUE_PROP,
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
  </head>
  <body>
    <a href="#main" class="skip-link">Skip to content</a>
    <Header />
    <slot />
    <Footer />
  </body>
</html>
