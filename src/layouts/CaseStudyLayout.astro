---
// CaseStudyLayout — the page frame for a single project case study. It wraps
// BaseLayout (so the sticky Header, Footer, and brand tokens all come through
// unchanged) and owns the reading surface: a single <h1> (the project title —
// the ONLY h1 on the page; the rendered markdown body uses ## and below), a short
// meta row (tech chips + a repo link), then a <slot /> for the rendered
// Problem/Approach/Outcome prose. A "← Back to work" link returns to the hub's
// #work section. The prose is capped to a ~65ch measure and its slotted markdown
// elements (h2/h3/p/ul/code/…) are styled via `.prose :global(...)` — scoped
// styles alone never reach <Content /> output, since that content is injected
// through the slot and carries no scope attribute.
import BaseLayout from "./BaseLayout.astro";
import { SITE_NAME, ANCHORS } from "../consts";

interface Props {
  /** Project display name — rendered as the page's single <h1>. */
  title: string;
  /** Tech-stack labels, rendered as chips in the meta row. */
  tech: string[];
  /** Source-repo URL — the meta row's "View code" link, when one exists. */
  repo?: string;
  /** Meta description for <head>; falls through to BaseLayout's default if unset. */
  description?: string;
}

const { title, tech, repo, description } = Astro.props;

// Document <title>: distinct per case study, and clearly a case study.
const docTitle = `${title} — Case Study · ${SITE_NAME}`;
// Base-safe hub link: BASE_URL always ends in "/", so this yields "/#work" at the
// site root (base '/') and stays correct under a project base path too.
const workHref = `${import.meta.env.BASE_URL}#${ANCHORS.work}`;
---

<BaseLayout title={docTitle} description={description}>
  <main id="main" class="case-study">
    <article class="case-study-inner">
      <a class="back-link" href={workHref}>
        <span aria-hidden="true">←</span> Back to work
      </a>

      <header class="case-study-header">
        <h1 class="case-study-title">{title}</h1>
        {
          (tech.length > 0 || repo) && (
            <div class="case-study-meta">
              {tech.length > 0 && (
                <ul class="case-study-tech" role="list" aria-label="Tech stack">
                  {tech.map((label) => (
                    <li class="tech-chip">{label}</li>
                  ))}
                </ul>
              )}
              {repo && (
                <a
                  class="meta-link"
                  href={repo}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={`${title} source code on GitHub (opens in a new tab)`}
                >
                  View code <span aria-hidden="true">↗</span>
                </a>
              )}
            </div>
          )
        }
      </header>

      <div class="prose">
        <slot />
      </div>
    </article>
  </main>
</BaseLayout>

<style>
  .case-study {
    padding: var(--space-8) var(--space-4) var(--space-9);
    background-color: var(--color-semantic-bg);
  }

  .case-study-inner {
    max-width: 48rem;
    margin-inline: auto;
  }

  .back-link {
    display: inline-block;
    margin-bottom: var(--space-6);
    color: var(--color-semantic-accent);
    font-weight: var(--type-weight-medium);
    text-decoration: none;
  }

  .back-link:hover {
    text-decoration: underline;
  }

  .case-study-header {
    padding-bottom: var(--space-5);
    border-bottom: 1px solid var(--color-semantic-border);
  }

  .case-study-title {
    margin: 0;
    color: var(--color-semantic-text);
    font-family: var(--font-heading);
    font-size: var(--type-scale-step-4);
    font-weight: var(--type-weight-bold);
    line-height: var(--type-line-height-tight);
  }

  .case-study-meta {
    margin-top: var(--space-4);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-3) var(--space-5);
  }

  .case-study-tech {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
  }

  /* Same visual as ProjectCard's chips (scoped styles don't cross components, so
   * the pill treatment is redefined here rather than shared). */
  .tech-chip {
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-pill);
    background-color: var(--color-semantic-code-bg);
    color: var(--color-semantic-text-muted);
    font-family: var(--font-mono);
    font-size: var(--type-scale-step--1);
    line-height: var(--type-line-height-tight);
    white-space: nowrap;
  }

  .meta-link {
    color: var(--color-semantic-accent);
    font-size: var(--type-scale-step-0);
    font-weight: var(--type-weight-medium);
    text-decoration: none;
    white-space: nowrap;
  }

  .meta-link:hover {
    text-decoration: underline;
  }

  /* Reading column: ~65ch measure for comfortable line length. */
  .prose {
    max-width: 65ch;
    margin-top: var(--space-7);
    color: var(--color-semantic-text);
    font-size: var(--type-scale-step-0);
    line-height: var(--type-line-height-loose);
  }

  /* Slotted markdown (from <Content />) carries no scope attribute, so its
   * elements are reached with `.prose :global(...)`, which compiles to
   * `.prose[scope] <tag>` — the .prose wrapper is scoped, the descendants global. */
  .prose :global(h2) {
    margin: var(--space-7) 0 var(--space-3);
    color: var(--color-semantic-text);
    font-family: var(--font-heading);
    font-size: var(--type-scale-step-2);
    font-weight: var(--type-weight-bold);
    line-height: var(--type-line-height-tight);
  }

  .prose :global(h3) {
    margin: var(--space-5) 0 var(--space-2);
    color: var(--color-semantic-text);
    font-family: var(--font-heading);
    font-size: var(--type-scale-step-1);
    font-weight: var(--type-weight-semibold);
    line-height: var(--type-line-height-tight);
  }

  /* Tighten the gap when a heading is the very first prose block. */
  .prose :global(:is(h2, h3):first-child) {
    margin-top: 0;
  }

  .prose :global(p) {
    margin: 0 0 var(--space-4);
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin: 0 0 var(--space-4);
    padding-left: var(--space-6);
  }

  .prose :global(li) {
    margin-bottom: var(--space-2);
  }

  .prose :global(li)::marker {
    color: var(--color-semantic-text-muted);
  }

  .prose :global(strong) {
    color: var(--color-semantic-text);
    font-weight: var(--type-weight-semibold);
  }

  .prose :global(a) {
    color: var(--color-semantic-accent);
    text-decoration: underline;
  }

  .prose :global(code) {
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-sm);
    background-color: var(--color-semantic-code-bg);
    color: var(--color-semantic-text);
    font-family: var(--font-mono);
    font-size: var(--type-scale-step--1);
  }

  .prose :global(pre) {
    margin: 0 0 var(--space-4);
    padding: var(--space-4);
    overflow-x: auto;
    border-radius: var(--radius-md);
    background-color: var(--color-semantic-code-bg);
  }

  /* Reset the inline chrome for code inside a fenced block. */
  .prose :global(pre code) {
    padding: 0;
    background-color: transparent;
    font-size: var(--type-scale-step--1);
  }

  .prose :global(blockquote) {
    margin: 0 0 var(--space-4);
    padding-left: var(--space-4);
    border-left: 3px solid var(--color-semantic-border);
    color: var(--color-semantic-text-muted);
  }
</style>
